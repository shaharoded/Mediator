<?xml version="1.0" encoding="UTF-8"?>
<state name="GLUCOSE_MEASURE_STATE">
    <categories>Measurements</categories>
    <description>Abstraction for the measurements of GLUCOSE (Lab / Capillary)</description>
    <derived-from name="GLUCOSE_MEASURE" tak="raw-concept"/>

    <!-- Allow fast paste changing state, no smoothing -->
    <persistence good-after="24h" interpolate="false"/>

    <abstraction-rules>
        <rule value="Critical Hypoglycemia" operator="and">
            <attribute idx="0">
                <allowed-value max="40"/>
            </attribute>
        </rule>
        <rule value="Severe Hypoglycemia" operator="and">
            <attribute idx="0">
                <allowed-value min="40" max="54"/>
            </attribute>
        </rule>
        <rule value="Hypoglycemia" operator="and">
            <attribute idx="0">
                <allowed-value min="54" max="70"/>
            </attribute>
        </rule>
        <rule value="Controlled Glucose" operator="and">
            <attribute idx="0">
                <allowed-value min="70" max="140"/>
            </attribute>
        </rule>
        <rule value="Moderate Glucose" operator="and">
            <attribute idx="0">
                <allowed-value min="140" max="180"/>
            </attribute>
        </rule>
        <rule value="Hyperglycemia" operator="and">
            <attribute idx="0">
                <allowed-value min="180" max="250"/>
            </attribute>
        </rule>
        <rule value="Severe Hyperglycemia" operator="and">
            <attribute idx="0">
                <allowed-value min="250" max="400"/>
            </attribute>
        </rule>
        <rule value="Extreme Hyperglycemia" operator="and">
            <attribute idx="0">
                <allowed-value min="400" max="600"/>
            </attribute>
        </rule>
        <rule value="HHS-Range Hyperglycemia" operator="and">
            <attribute idx="0">
                <allowed-value min="600"/>
            </attribute>
        </rule>
    </abstraction-rules>
</state>